# Production environment variables — baked at build time
# NEXT_PUBLIC_* vars are inlined by Next.js during `next build`

# Mock API — all API calls intercepted client-side
NEXT_PUBLIC_MOCK_API=true

# Staging auth gate — disabled for demo (public pages should be accessible)
# Platform pages are gated by RequireAuth + demo personas
# NEXT_PUBLIC_STAGING_AUTH=true
