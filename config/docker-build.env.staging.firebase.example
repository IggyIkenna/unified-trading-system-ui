# =============================================================================
# Staging portal — Firebase web client (template). Safe to commit; contains no secrets.
#
# 1. Create a dedicated non-production Firebase project (separate from prod web keys).
# 2. Register authorized domains for your staging hosts (e.g. odumresearch.co.uk,
#    odum-research.co.uk, and the Cloud Run hostname if used directly).
# 3. Copy this file to a gitignored path (e.g. config/docker-build.env.staging.firebase.local),
#    replace REPLACE_ME values and optional URLs, then build/deploy:
#      bash scripts/deploy-cloud-run.sh --build-env-file=config/docker-build.env.staging.firebase.local
#    or Cloud Build:
#      bash scripts/deploy-cloud-run.sh --cloud --build-env-file=config/docker-build.env.staging.firebase.local
#
# Default committed staging (`docker-build.env.staging`) stays on demo auth until you cut over.
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://odumresearch.co.uk
NEXT_PUBLIC_MOCK_API=true
NEXT_PUBLIC_AUTH_PROVIDER=firebase
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_ME
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME
# Staging user-management / authorize host (8017-class). Leave empty only if unused.
NEXT_PUBLIC_USER_MGMT_API_URL=
# When you set NEXT_PUBLIC_MOCK_API=false, set the gateway bases used by next.config.mjs rewrites:
# NEXT_PUBLIC_API_BASE_URL=https://...
# NEXT_PUBLIC_AUTH_URL=https://...
# NEXT_PUBLIC_DEPLOYMENT_API_URL=https://...
# NEXT_PUBLIC_REPORTING_API_URL=https://...
NEXT_PUBLIC_STRATEGY_CATALOG_SOURCE=mock
NEXT_PUBLIC_STRATEGY_CATALOG_API_ERROR_FALLBACK=true
NEXT_PUBLIC_BRIEFING_ACCESS_CODE=
