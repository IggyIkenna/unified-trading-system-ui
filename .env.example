# Canonical site URL for metadata / OG (staging: https://odumresearch.co.uk, production: https://odumresearch.com)
# NEXT_PUBLIC_SITE_URL=https://odumresearch.co.uk
#
# Cloud Run / Docker: NEXT_PUBLIC_* is baked at image build time. Staging vs production images use
# `config/docker-build.env.staging` vs `config/docker-build.env.production` (see Dockerfile BUILD_ENV_FILE
# and `scripts/deploy-cloud-run.sh`). Runtime Cloud Run env cannot switch Firebase ↔ demo for an existing image.

# ──────────────────────────────────────────────────────────────────────────
# Local development — Firebase Emulator Suite (SSOT).
# ──────────────────────────────────────────────────────────────────────────
# Local dev runs against Firebase Auth + Firestore + Storage emulators on
# localhost. Same code path as staging / prod; only the project ID + emulator
# host vars change. Per codex/14-playbooks/authentication/firebase-local.md.
#
# Boot the stack:   bash scripts/dev-tiers.sh --tier 0
# Seed personas:    npm run emulators:seed   (once, after first emulator boot)
NEXT_PUBLIC_AUTH_PROVIDER=firebase
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=odum-local-dev

# ──────────────────────────────────────────────────────────────────────────
# Mock-API mode (CI / build smoke / static demos only — NOT for local dev).
# ──────────────────────────────────────────────────────────────────────────
# Used by the Tier-0 CI smoke gate and `pnpm build` smoke tests where no
# backend is available. Do NOT enable for interactive local dev — it bypasses
# Firebase entirely (no auth, no Firestore) and produced a half-mock /
# half-firebase state when mixed with the SSOT (incident 2026-04-27).
# NEXT_PUBLIC_MOCK_API=true

# API base URL (only used when NEXT_PUBLIC_MOCK_API=false)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8004

# Skip auth (set to "true" for local dev without OAuth)
NEXT_PUBLIC_SKIP_AUTH=true

# Firebase Auth config — REAL-GCP overrides for staging / prod images.
# Local dev uses the emulator preset above; these are only consulted when
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR is unset (CI builds, deployed images).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=central-element-323112.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID is set above (local-dev default `odum-local-dev`).
# Staging / prod images set this via config/docker-build.env.{staging,production}.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=central-element-323112.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# User Management API base URL (authorize, entitlements, POST /api/v1/signup).
# Production must point at an image that includes the signup route (user-management-ui server).

# Firebase Storage: onboarding uploads use path onboarding-docs/... . If uploads return 403, relax
# Storage rules for that prefix or issue signed upload URLs from your API (Firebase Console → Storage → Rules).

# ---------------------------------------------------------------------------
# Admin catalogue truthiness adapter (lib/admin/truthiness.ts).
# Reconciles UAC canonical lists against live backend registry state. Used by
# the `(ops)/admin/strategy-catalogue/*` pages via `useCatalogueTruthiness`.
#
# ALL THREE must be set for live mode. If any is missing, or CLOUD_MOCK_MODE=true,
# the adapter short-circuits to mock seed data (tagged `(mock)` in the UI).
#
# Secret provenance: NEXT_PUBLIC_ADMIN_API_TOKEN is a shared per-environment
# secret. Rotation lives with Secret Manager (see codex
# 09-strategy/architecture-v2/admin-registry-api.md § Client config).
# ---------------------------------------------------------------------------
# Shared admin secret sent as the X-Admin-Token header. Rotate via Secret Manager.
NEXT_PUBLIC_ADMIN_API_TOKEN=
# strategy-service base URL (serves /api/v1/registry/archetypes + /ml-models).
NEXT_PUBLIC_STRATEGY_SERVICE_URL=http://localhost:8016
# JSON map of {service_key: base_url} for mounted features-* services.
# Example: {"features-onchain":"http://localhost:8012","features-sports":"http://localhost:8014"}
NEXT_PUBLIC_FEATURES_SERVICE_URLS=
