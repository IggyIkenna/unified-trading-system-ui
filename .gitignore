# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.npmrc
.snowflake/
.v0-trash/
next.user-config.*

# Environment variables
.env*.local
.env
.env.production
# Staging Firebase bake file (copy of config/docker-build.env.staging.firebase.example)
config/docker-build.env.staging.firebase.local

# Common ignores
node_modules/
.next/
.DS_Store

# Playwright / test runner outputs
test-results/
playwright-report/

# Archive/backup zips
*.zip
/coverage/

# pnpm is canonical — block npm's lockfile from being re-committed
package-lock.json

# Build / test output routed into a single folder (see vitest.config.ts,
# playwright.*.config.ts, tsconfig.json)
/build-artifacts/

# Next / misc build outputs
next-env.d.ts
dist/
out/
build/
storybook-static/

# Playwright MCP scratch dir (separate from test artifacts)
.playwright-mcp/

# Stray screenshots from MCP / Playwright agents must never land in repo root.
# Subdir PNGs (public/, docs/, context/) are unaffected.
/*.png

# Local dev cache and logs (machine-generated, never commit)
.local-dev-cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Firebase deploy cache (machine-generated, never commit)
.firebase/

# macOS metadata (never commit)
.DS_Store
**/.DS_Store

# Claude Code worktrees
.claude/
