// Firebase Storage security rules.
// Deployed via:
//   firebase --project odum-staging deploy --only storage
//   firebase --project central-element-323112 deploy --only storage
//
// SSOT mirrors firestore.rules for the same-audience collections — any
// prospect who can anonymously submit a Firestore document can also
// upload the corresponding evidence files, and the same admin / IM-desk
// custom claims that read the Firestore doc can read the blobs.

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // --------------------------------------------------------------
    // Strategy Evaluation DDQ attachments.
    // Public /strategy-evaluation form uploads evidence (methodology
    // doc, tear sheet, trade log CSV, etc.) at:
    //   strategy-evaluations/{draftSubmissionId}/{fieldKey}/{timestamp-filename}
    // Anonymous create only — no overwrites, no deletes from the public
    // surface. Reads gated to admin / IM desk custom claims.
    // 50MB per-file cap + basic content-type allow-list to reduce abuse.
    // --------------------------------------------------------------
    match /strategy-evaluations/{draftId}/{fieldKey}/{filename} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.im_desk == true
      );
      // 500 MB cap is the real abuse guard. Trade-log CSVs from HFT or
      // multi-year backtests routinely run 100 MB+, so the previous 50 MB
      // ceiling rejected legitimate uploads. We previously had a content-type
      // allow-list too but it kept rejecting `.md` / exotic CSV mime variants
      // because browsers vary on what File.type they report — dropped that
      // filter; size + path shape (draft id + fieldKey + filename) is enough.
      allow create: if request.resource.size < 500 * 1024 * 1024;
      allow update, delete: if request.auth != null
                            && request.auth.token.admin == true;
    }

    // Default deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
