# Mock Mode — enables fully interactive mock without backend
VITE_MOCK_API=true
VITE_SKIP_AUTH=true

# Optional: add response latency for realistic feel
VITE_MOCK_DELAY_MS=60

# Optional: stress test scenarios
# VITE_STRESS_SCENARIO=BIG_DRAWDOWN
# VITE_STRESS_SCENARIO=HIGH_CARDINALITY
# VITE_STRESS_SCENARIO=MISSING_DATA
# VITE_STRESS_SCENARIO=BAD_SCHEMAS
# VITE_STRESS_SCENARIO=STALE_DATA
# VITE_STRESS_SCENARIO=BIG_TICKS

# Production API (when VITE_MOCK_API=false)
# VITE_API_URL=http://localhost:8004

# OAuth (when VITE_SKIP_AUTH=false)
# VITE_OAUTH_CLIENT_ID=your-google-client-id
# VITE_COGNITO_CLIENT_ID=your-cognito-client-id
# VITE_COGNITO_DOMAIN=https://your-domain.auth.region.amazoncognito.com
# VITE_COGNITO_REDIRECT_URI=http://localhost:5183/auth/callback

# Cross-UI navigation (when VITE_MOCK_API=false)
# VITE_ONBOARDING_URL=http://localhost:5173
