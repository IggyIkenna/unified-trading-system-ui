# VERSA — Execution Analytics UI Environment Configuration
# Copy this file to .env.development for local dev with mock data

# ── UI Data Mode ──────────────────────────────────────────────────────────────
# true  = window.fetch interceptor serves mock data (no backend required)
# false = live API calls to VITE_API_URL
VITE_MOCK_API=true

# ── UI Auth Mode ──────────────────────────────────────────────────────────────
# true  = skip OAuth entirely, use a synthetic session token
# false = require Google/Cognito login
VITE_SKIP_AUTH=true

# ── API Base URL ──────────────────────────────────────────────────────────────
# Used when VITE_MOCK_API=false; must NOT have a trailing slash
VITE_API_URL=http://localhost:8006

# ── OAuth (only required when VITE_SKIP_AUTH=false) ──────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_REDIRECT_URI=http://localhost:5174/auth/callback
