# Terraform variables for AWS Shared Infrastructure
# Copy this file to terraform.tfvars and customize

# AWS Region (Tokyo - same region as GCP asia-northeast1)
region = "ap-northeast-1"

# Environment
environment = "prod"

# VPC Configuration
create_vpc         = true
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-northeast-1a", "ap-northeast-1c"]

# S3 Buckets
create_s3_buckets             = true
create_terraform_state_bucket = true

# ECR Repositories
create_ecr_repositories = true

# IAM Roles
create_iam_roles = true

# Secrets (creates empty secrets - you'll need to populate values manually)
create_secrets = true

# Batch Configuration
create_batch_environment = true
batch_max_vcpus          = 16
