# Example terraform.tfvars for instruments-service on AWS
# Copy to terraform.tfvars and fill in your values

# AWS Region
region = "ap-northeast-1"

# Job Configuration
job_name     = "instruments-service"
docker_image = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/instruments-service:latest"

vcpus           = "2"
memory_mb       = "4096"
timeout_seconds = 3600
max_retries     = 3
environment     = "prod"

# IAM Roles (from shared-infrastructure module)
execution_role_arn = "arn:aws:iam::123456789012:role/trading-execution-role"
job_role_arn       = "arn:aws:iam::123456789012:role/trading-job-role"

# Networking (from shared-infrastructure module)
subnet_ids         = ["subnet-abc123", "subnet-def456"]
security_group_ids = ["sg-abc123"]
job_queue_arn      = "arn:aws:batch:ap-northeast-1:123456789012:job-queue/trading-queue"

# S3 Buckets
s3_bucket_cefi   = "instruments-store-cefi"
s3_bucket_tradfi = "instruments-store-tradfi"
s3_bucket_defi   = "instruments-store-defi"

# Secrets (ARNs from AWS Secrets Manager)
tardis_secret_arn    = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:tardis-api-key-AbCdEf"
databento_secret_arn = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:databento-api-key-GhIjKl"
alchemy_secret_arn   = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:alchemy-api-key-MnOpQr"
graph_secret_arn     = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:graph-api-key-StUvWx"

# Workflow Configuration
workflow_name = "instruments-service-daily"

# Scheduler Configuration
schedule  = "30 8 * * *"  # 8:30 AM UTC daily
time_zone = "UTC"
