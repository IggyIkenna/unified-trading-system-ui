# Example terraform.tfvars for ml-training-service on AWS
# Copy to terraform.tfvars and fill in your values

# AWS Region
region = "ap-northeast-1"

# Job Configuration
job_name     = "ml-training-service"
docker_image = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/ml-training-service:latest"

vcpus           = "8"
memory_mb       = "16384"
timeout_seconds = 14400  # 4 hours
max_retries     = 2
environment     = "prod"

# IAM Roles (from shared-infrastructure module)
execution_role_arn = "arn:aws:iam::123456789012:role/trading-execution-role"
job_role_arn       = "arn:aws:iam::123456789012:role/trading-job-role"

# Networking (from shared-infrastructure module)
subnet_ids         = ["subnet-abc123", "subnet-def456"]
security_group_ids = ["sg-abc123"]
job_queue_arn      = "arn:aws:batch:ap-northeast-1:123456789012:job-queue/trading-queue"

# S3 Buckets
ml_models_bucket  = "ml-models-store"
ml_configs_bucket = "ml-configs-store"
features_bucket   = "features-delta-one-cefi"

# Workflow Configuration
workflow_name = "ml-training-service-daily"

# Scheduler Configuration
schedule  = "0 12 * * *"  # 12:00 PM UTC daily
time_zone = "UTC"
