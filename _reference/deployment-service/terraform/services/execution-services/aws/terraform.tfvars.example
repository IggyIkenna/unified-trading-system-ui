# Example terraform.tfvars for execution-services on AWS
# Copy to terraform.tfvars and fill in your values

# AWS Region
region = "ap-northeast-1"

# Job Configuration
job_name     = "execution-services"
docker_image = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/execution-services:latest"

vcpus           = "8"
memory_mb       = "16384"
timeout_seconds = 14400  # 4 hours
max_retries     = 2
environment     = "prod"

# IAM Roles (from shared-infrastructure module)
execution_role_arn = "arn:aws:iam::123456789012:role/trading-execution-role"
job_role_arn       = "arn:aws:iam::123456789012:role/trading-job-role"

# Networking (from shared-infrastructure module)
subnet_ids         = ["subnet-abc123", "subnet-def456"]
security_group_ids = ["sg-abc123"]
job_queue_arn      = "arn:aws:batch:ap-northeast-1:123456789012:job-queue/trading-queue"

# S3 Buckets - Execution output
execution_bucket_cefi   = "execution-store-cefi"
execution_bucket_tradfi = "execution-store-tradfi"
execution_bucket_defi   = "execution-store-defi"

# S3 Buckets - Tick data input
tick_data_bucket_cefi   = "market-data-tick-cefi"
tick_data_bucket_tradfi = "market-data-tick-tradfi"
tick_data_bucket_defi   = "market-data-tick-defi"

# S3 Buckets - Strategy signals input
strategy_bucket_cefi   = "strategy-store-cefi"
strategy_bucket_tradfi = "strategy-store-tradfi"
strategy_bucket_defi   = "strategy-store-defi"

# Workflow Configuration
workflow_name = "execution-services-daily"

# Scheduler Configuration
schedule  = "0 15 * * *"  # 3:00 PM UTC daily
time_zone = "UTC"
