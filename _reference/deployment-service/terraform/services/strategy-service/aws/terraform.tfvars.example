# Example terraform.tfvars for strategy-service on AWS
# Copy to terraform.tfvars and fill in your values

# AWS Region
region = "ap-northeast-1"

# Job Configuration
job_name     = "strategy-service"
docker_image = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/strategy-service:latest"

vcpus           = "4"
memory_mb       = "8192"
timeout_seconds = 7200
max_retries     = 3
environment     = "prod"

# IAM Roles (from shared-infrastructure module)
execution_role_arn = "arn:aws:iam::123456789012:role/trading-execution-role"
job_role_arn       = "arn:aws:iam::123456789012:role/trading-job-role"

# Networking (from shared-infrastructure module)
subnet_ids         = ["subnet-abc123", "subnet-def456"]
security_group_ids = ["sg-abc123"]
job_queue_arn      = "arn:aws:batch:ap-northeast-1:123456789012:job-queue/trading-queue"

# S3 Buckets - Strategy output
strategy_bucket_cefi   = "strategy-store-cefi"
strategy_bucket_tradfi = "strategy-store-tradfi"
strategy_bucket_defi   = "strategy-store-defi"

# S3 Buckets - Input
features_bucket    = "features-delta-one-cefi"
predictions_bucket = "ml-predictions-store"

# Workflow Configuration
workflow_name = "strategy-service-daily"

# Scheduler Configuration
schedule  = "0 14 * * *"  # 2:00 PM UTC daily
time_zone = "UTC"
