# Terraform variables for strategy-service
# Copy this file to terraform.tfvars and update with your project details

# Project configuration - will be resolved dynamically in production via metadata service
project_id   = "your-gcp-project-id"
region       = "asia-northeast1"
gcs_location = "asia-northeast1"
environment  = "prod"

# These will be dynamically generated based on project_id
job_name     = "strategy-service-job"
docker_image = "asia-northeast1-docker.pkg.dev/your-gcp-project-id/strategy-service/strategy-service:latest"

# Service account emails will be dynamically generated as service-name@{project_id}.iam.gserviceaccount.com
service_account_email           = "strategy-service-sa@your-gcp-project-id.iam.gserviceaccount.com"
scheduler_service_account_email = "strategy-service-sa@your-gcp-project-id.iam.gserviceaccount.com"

cpu             = "2"
memory          = "8Gi"
timeout_seconds = 86400
max_retries     = 3

# Bucket names will be dynamically generated as bucket-type-{project_id}
strategy_bucket_cefi   = "strategy-store-cefi-your-gcp-project-id"
strategy_bucket_tradfi = "strategy-store-tradfi-your-gcp-project-id"
strategy_bucket_defi   = "strategy-store-defi-your-gcp-project-id"

workflow_name          = "strategy-service-daily"
backfill_workflow_name = "strategy-service-backtest"

# Schedule at 15:00 PM UTC (after inference)
schedule  = "0 15 * * *"
time_zone = "UTC"
