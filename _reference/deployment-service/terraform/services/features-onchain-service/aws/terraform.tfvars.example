# Example terraform.tfvars for features-onchain-service on AWS
# Copy to terraform.tfvars and fill in your values
# Note: TRADFI is NOT supported (no on-chain data)

# AWS Region
region = "ap-northeast-1"

# Job Configuration
job_name     = "features-onchain-service"
docker_image = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/features-onchain-service:latest"

vcpus           = "2"
memory_mb       = "4096"
timeout_seconds = 1800
max_retries     = 3
environment     = "prod"

# IAM Roles (from shared-infrastructure module)
execution_role_arn = "arn:aws:iam::123456789012:role/trading-execution-role"
job_role_arn       = "arn:aws:iam::123456789012:role/trading-job-role"

# Networking (from shared-infrastructure module)
subnet_ids         = ["subnet-abc123", "subnet-def456"]
security_group_ids = ["sg-abc123"]
job_queue_arn      = "arn:aws:batch:ap-northeast-1:123456789012:job-queue/trading-queue"

# S3 Buckets - Input (candles)
# Only CEFI and DEFI - no TRADFI (no on-chain data)
s3_bucket_cefi = "market-data-tick-cefi"
s3_bucket_defi = "market-data-tick-defi"

# S3 Buckets - Output (onchain features)
features_bucket_cefi = "features-onchain-cefi"
features_bucket_defi = "features-onchain-defi"

# Secrets (ARNs from AWS Secrets Manager)
alchemy_secret_arn = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:alchemy-api-key-AbCdEf"
graph_secret_arn   = "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:graph-api-key-GhIjKl"

# Workflow Configuration
workflow_name = "features-onchain-service-daily"

# Scheduler Configuration
schedule  = "30 10 * * *"  # 10:30 AM UTC daily
time_zone = "UTC"
