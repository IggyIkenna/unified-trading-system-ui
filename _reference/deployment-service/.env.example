# =============================================================================
# Unified Trading Deployment - Environment Variables
# =============================================================================
# This file is the TEMPLATE for all configuration. Two usage paths:
#
# LOCAL DEVELOPMENT:
#   cp .env.example .env.local    # then adjust values for local dev
#   ./run-api.sh                  # sources .env.local automatically
#
# DOCKER / PRODUCTION:
#   cp .env.example .env          # then adjust values for production
#   docker compose up --build     # docker-compose.yml loads .env via env_file
#
# CLOUD RUN:
#   cloudbuild.yaml passes env vars via --set-env-vars at deploy time.

# =============================================================================
# CORE GCP CONFIGURATION
# =============================================================================
# GCP_PROJECT_ID will be dynamically resolved from Secret Manager or metadata service
# For local development, uncomment and set your project ID:
# GCP_PROJECT_ID=your-gcp-project-id

# GCS_REGION is the primary region for ALL operations (VMs, Cloud Run, GCS bucket).
# Deploying to a different region will incur cross-region egress costs.
# Zone failover happens within this region (e.g., 1a -> 1b -> 1c).
GCS_REGION=asia-northeast1
# STATE_BUCKET will be dynamically generated as deployment-orchestration-{project_id}
# For local development, uncomment and set your bucket:
# STATE_BUCKET=deployment-orchestration-your-project-id
# SERVICE_ACCOUNT will be dynamically generated as service-name@{project_id}.iam.gserviceaccount.com
# For local development, uncomment and set your service account:
# SERVICE_ACCOUNT=instruments-service-cloud-run@your-project-id.iam.gserviceaccount.com

# GitHub organization (used for Cloud Build triggers, code push detection)
GITHUB_ORG=IggyIkenna

# GitHub token service account (used for impersonation to access GitHub token)
# GITHUB_TOKEN_SA will be dynamically generated as github-token-sa@{project_id}.iam.gserviceaccount.com
# For local development, uncomment and set your service account:
# GITHUB_TOKEN_SA=github-token-sa@your-project-id.iam.gserviceaccount.com

# Cloud provider: gcp or aws
CLOUD_PROVIDER=gcp

# =============================================================================
# VM HEALTH MONITORING
# =============================================================================
# Terminate VMs with OOM death loops (gcsfuse repeatedly killed by kernel)
OOM_KILL_THRESHOLD=5
# Terminate VMs that don't emit startup signal after N seconds
VM_STARTUP_TIMEOUT_SECONDS=300
# State TTL: cleanup old deployment states (keep last N hours)
STATE_TTL_HOURS=48
# Orphan VM deletion: fire-and-forget parallel termination (within write quota)
ORPHAN_DELETE_MAX_PARALLEL=500
ORPHAN_DELETE_RETRY_SECONDS=30
# Orphan cleanup for deployments marked completed in last N minutes (catches missed VM deletes)
ORPHAN_CLEANUP_RECENTLY_COMPLETED_MINUTES=30

# GCP Compute write quota: effective budget = WRITE_QUOTA_PER_MINUTE - WRITE_QUOTA_BUFFER (e.g. 5000/min)
WRITE_QUOTA_PER_MINUTE=6000
WRITE_QUOTA_BUFFER=1000

# =============================================================================
# STATE FILE ENVIRONMENT SEPARATION
# =============================================================================
# Separates state files between development and production to prevent conflicts
# between local development and Cloud Run service.
#
# Values:
#   - development : State stored in deployments.development/  (use in .env.local)
#   - production  : State stored in deployments.production/   (use in .env / Docker)
#
# GCS FUSE: When production, the deployment API uses GCS FUSE (Cloud Run volume
# mounts) for faster list/exists. Local dev always uses GCS API - no FUSE.
DEPLOYMENT_ENV=development

# GCS FUSE mount path for pipeline jobs (VM and Cloud Run). When set, unified-trading-services
# reads parquet from /mnt/gcs/{bucket}/... instead of GCS API. Do NOT set
# UNIFIED_CLOUD_SERVICES_USE_DIRECT_GCS when using FUSE.
# GCS_FUSE_MOUNT_PATH=/mnt/gcs

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Backend port
#   - Local dev (.env.local): set to 8000 (uvicorn direct)
#   - Docker (.env):          set to 8080 (gunicorn, matches EXPOSE in Dockerfile)
API_PORT=8000

# Frontend dev server port (Vite) -- only relevant for local dev
FRONTEND_PORT=5173

# Number of gunicorn/uvicorn workers
WORKERS=4

# =============================================================================
# AUTO-SYNC CONFIGURATION
# =============================================================================
# Enable/disable auto-sync background task (monitors running deployments)
AUTO_SYNC_ENABLED=true

# Auto-sync interval in seconds (how often to check deployment status)
AUTO_SYNC_INTERVAL_SECONDS=60
# Sync interval when active (faster = quicker orphan VM kill); default 5
AUTO_SYNC_INTERVAL_ACTIVE=5
# Concurrent deployment processors (higher = faster); default 10
AUTO_SYNC_MAX_PARALLEL=10

# Lock TTL in seconds (must be > sync interval to prevent conflicts)
AUTO_SYNC_LOCK_TTL_SECONDS=90

# =============================================================================
# AUTO-SCHEDULER CONFIGURATION
# =============================================================================
# Maximum concurrent shards across all deployments
DEFAULT_MAX_CONCURRENT=2000

# Hard limit on concurrent shards (cannot be exceeded even by override)
MAX_CONCURRENT_HARD_LIMIT=2500

# Max shard launches per scheduler tick
AUTO_SCHEDULER_MAX_LAUNCH_PER_TICK=2000

# Max shard releases (completions) per scheduler tick
AUTO_SCHEDULER_MAX_RELEASES_PER_TICK=200

# Batch size for shard processing
AUTO_SCHEDULER_BATCH_SIZE=200

# Delay between batches in seconds
AUTO_SCHEDULER_INTER_BATCH_DELAY=1.0

# VM self-delete batching (stagger deletes to avoid GCP rate limits)
AUTO_SCHEDULER_DELETE_BATCH_SIZE=200
AUTO_SCHEDULER_DELETE_BATCH_DELAY_SECONDS=45

# Number of parallel workers for auto-scheduler
AUTO_SCHEDULER_PARALLEL_WORKERS=56

# VM launch rate limit (requests per second)
AUTO_SCHEDULER_VM_RATE_LIMIT=10.0

# Grace period before marking a shard as stuck (seconds)
STUCK_SHARD_GRACE_SECONDS=600

# =============================================================================
# VM ORCHESTRATION
# =============================================================================
# Number of VMs to launch per mini-batch (peak ~2000 inserts per 30s with delay 3s)
VM_LAUNCH_MINI_BATCH_SIZE=200

# Delay between VM mini-batches in seconds (insert + delete ≤ 2500/30s = 5000/min with buffer)
VM_LAUNCH_MINI_BATCH_DELAY_SECONDS=3

# Max polls before treating unknown VM status as failed
UNKNOWN_STATUS_MAX_POLLS=10

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# GCS connection pool size
GCS_POOL_SIZE=200

# Compute API connection pool size
COMPUTE_POOL_SIZE=200
COMPUTE_POOL_MAXSIZE=200

# =============================================================================
# REDIS CACHE (optional)
# =============================================================================
# Uncomment to enable Redis caching (falls back to in-memory if unavailable)
# REDIS_URL=redis://localhost:6379/0

# Data status cache TTL in seconds (default: 30 minutes)
DATA_STATUS_CACHE_TTL_SECONDS=1800

# =============================================================================
# QUOTA BROKER (optional)
# =============================================================================
# URL of the quota broker service (leave empty to disable)
# QUOTA_BROKER_URL=
# QUOTA_BROKER_AUTH_MODE=iam
# QUOTA_BROKER_TIMEOUT_SECONDS=10.0
# BROKER_MAX_WAIT_SECONDS=900

# =============================================================================
# INSTRUMENT DOWNLOAD CONFIGURATION
# =============================================================================
# Worker counts auto-scale based on available CPU cores:
# - INSTRUMENT_DOWNLOAD_WORKERS = min(64, cpu_count * 4)  [I/O bound]
# - INSTRUMENT_LIST_WORKERS = min(32, cpu_count * 2)      [API bound]
#
# Override with explicit values if needed:
# INSTRUMENT_DOWNLOAD_WORKERS=64
# INSTRUMENT_LIST_WORKERS=32

# =============================================================================
# TESTING
# =============================================================================
# Set to "true" to use mock cloud clients (for testing without GCP access)
# CLOUD_MOCK_MODE=false

# =============================================================================
# CORS & AUTH (Cloud Run production)
# =============================================================================
# Comma-separated allowed origins (required for production)
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com
# Cloud Run services allowed to call this API (e.g. deployment-dashboard,execution-services)
# CORS_ALLOWED_CLOUD_RUN=deployment-dashboard,execution-services
# OAuth: domain for Google OIDC (replace company.com with your domain)
# OAUTH_AUTHORIZED_DOMAIN=yourcompany.com

# =============================================================================
# GITHUB AUTHENTICATION (for local dev & CI)
# =============================================================================
# GitHub Personal Access Token for cloning private deps, quality gates.
# Create at: https://github.com/settings/tokens (repo scope)
# Local: add to .env or export GH_PAT=...; CI: add GH_PAT in repo Settings → Secrets
GH_PAT=
