{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Odum Strategy Performance",
  "uid": "odum-strategy",
  "version": 2,
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Signal Processing Rate by Status",
      "description": "Rate of strategy_service_records_processed_total broken down by status label",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(strategy_service_records_processed_total[5m]) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Processing Latency P50 / P95 / P99",
      "description": "Percentile latencies from strategy_service_processing_latency_seconds histogram",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(strategy_service_processing_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(strategy_service_processing_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(strategy_service_processing_latency_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Error Rate",
      "description": "Ratio of error records to total records processed",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(strategy_service_records_processed_total{status=\"error\"}[5m]) / rate(strategy_service_records_processed_total[5m])",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Signal Throughput Over Time",
      "description": "Total records processed per second across all statuses",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(strategy_service_records_processed_total[5m]))",
          "legendFormat": "Total throughput"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(strategy_service_records_processed_total{status=\"success\"}[5m]))",
          "legendFormat": "Success"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(strategy_service_records_processed_total{status=\"error\"}[5m]))",
          "legendFormat": "Error"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
