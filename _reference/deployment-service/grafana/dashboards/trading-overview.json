{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Odum Trading Overview",
  "uid": "odum-trading-overview",
  "version": 2,
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Circuit Breaker State",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "circuit_breaker_state",
          "legendFormat": "{{strategy_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": { "0": { "text": "CLOSED", "color": "green" } },
              "type": "value"
            },
            {
              "options": { "1": { "text": "HALF-OPEN", "color": "yellow" } },
              "type": "value"
            },
            {
              "options": { "2": { "text": "OPEN", "color": "red" } },
              "type": "value"
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Trade Execution Latency (P95)",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(trade_execution_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 {{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Reconciliation Drift (USD)",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "reconciliation_drift_usd",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Position Notional (USD)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "position_notional_usd",
          "legendFormat": "{{strategy_id}} {{instrument_key}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PnL Drawdown %",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "pnl_drawdown_pct * 100",
          "legendFormat": "{{strategy_id}} {{client_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": -100, "color": "red" },
              { "value": -5, "color": "yellow" },
              { "value": 0, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Order Submission Rate (execution-service)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(execution_service_operations_total{operation_type=\"order_submit\"}[5m])",
          "legendFormat": "Orders/s {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Strategy Signal Emission Rate (strategy-service)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(strategy_service_operations_total{operation_type=\"signal_emit\"}[5m])",
          "legendFormat": "Signals/s {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "ML Inference Rate (ml-inference-service)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ml_inference_service_operations_total[5m])",
          "legendFormat": "Inferences/s {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "ML Inference Latency P95 (ml-inference-service)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(ml_inference_service_processing_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 latency"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Feature Calculation Rate (market-data-processing-service)",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(market_data_processing_service_records_processed_total[5m])",
          "legendFormat": "Records/s {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Risk Pre-Trade Check Latency P95 (risk-and-exposure-service)",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(risk_and_exposure_service_processing_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 latency"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
