{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Odum Execution",
  "uid": "odum-execution",
  "version": 2,
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Order Submission Rate by Exchange",
      "description": "Rate of order_submissions_total grouped by exchange",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(order_submissions_total[5m])) by (exchange)",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Order Status Breakdown",
      "description": "Order submission rate by status (success, rejected, timeout)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(order_submissions_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Execution Latency P95 by Exchange + Symbol",
      "description": "P95 trade execution latency from trade_execution_latency_seconds histogram",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(trade_execution_latency_seconds_bucket[5m])) by (le, exchange, symbol))",
          "legendFormat": "{{exchange}} {{symbol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Execution Latency Heatmap",
      "description": "Heatmap of trade_execution_latency_seconds bucket distribution over time",
      "gridPos": { "x": 0, "y": 16, "w": 14, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(trade_execution_latency_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Order Type Distribution",
      "description": "Current order submission counts by order_type label",
      "gridPos": { "x": 14, "y": 16, "w": 10, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(order_submissions_total[5m])) by (order_type)",
          "legendFormat": "{{order_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
