{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Odum System Health",
  "uid": "odum-system-health",
  "version": 2,
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API Request Latency P95 by Service",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(api_request_latency_seconds_bucket[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "PubSub Message Lag by Topic",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "pubsub_message_lag_seconds",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead Letter Queue Depth",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "dead_letter_queue_depth",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GCS Write Latency",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(gcs_write_latency_seconds_bucket[5m])) by (service, bucket)",
          "legendFormat": "{{service}} {{bucket}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Records Processed Rate by Service",
      "description": "Covers execution-service, strategy-service, risk-and-exposure-service, ml-inference-service, market-data-processing-service, alerting-service",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(records_processed_total[5m]) by (service, status)",
          "legendFormat": "{{service}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Processing Latency P95 by Service",
      "description": "Covers execution-service, strategy-service, risk-and-exposure-service, ml-inference-service, market-data-processing-service",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(processing_latency_seconds_bucket[5m])) by (service, operation_type)",
          "legendFormat": "{{service}} {{operation_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Service Memory Usage (RSS %)",
      "description": "Memory RSS as % of total — alert fires at 85% via pre-crash checkpoint",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "process_resident_memory_bytes / on() node_memory_MemTotal_bytes * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Alerting Service — Alert Emission Rate",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(alerting_service_operations_total[5m])",
          "legendFormat": "Alerts/s {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
