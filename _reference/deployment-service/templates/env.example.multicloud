# Multi-Cloud Environment Configuration Template
# Copy this to your service's .env.example and customize
#
# IMPORTANT: Set CLOUD_PROVIDER to switch between GCP and AWS

# =============================================================================
# CLOUD PROVIDER SELECTION
# =============================================================================
# Set to "gcp" for Google Cloud Platform or "aws" for Amazon Web Services
CLOUD_PROVIDER=gcp

# Optional: Override provider for specific services (hybrid cloud)
# SECRETS_CLOUD_PROVIDER=gcp  # Keep secrets on GCP even when using AWS
# STORAGE_CLOUD_PROVIDER=aws  # Use S3 even when main provider is GCP

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
SERVICE_NAME=your-service-name
LOG_LEVEL=INFO

# =============================================================================
# GCP CONFIGURATION (when CLOUD_PROVIDER=gcp)
# =============================================================================
GCP_PROJECT_ID={project_id}
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
GCS_REGION=asia-northeast1
GCS_LOCATION=US
BIGQUERY_LOCATION=US

# GCP Storage Buckets
# These are automatically mapped based on domain and category
INSTRUMENTS_GCS_BUCKET_CEFI=instrument-definitions-cefi-{project_id}
INSTRUMENTS_GCS_BUCKET_TRADFI=instrument-definitions-tradfi-{project_id}
INSTRUMENTS_GCS_BUCKET_DEFI=instrument-definitions-defi-{project_id}
MARKET_DATA_GCS_BUCKET_CEFI=market-data-tick-cefi-{project_id}
MARKET_DATA_GCS_BUCKET_TRADFI=market-data-tick-tradfi-{project_id}
MARKET_DATA_GCS_BUCKET_DEFI=market-data-tick-defi-{project_id}
FEATURES_GCS_BUCKET=features-{project_id}
EXECUTION_GCS_BUCKET=execution-store-cefi-{project_id}

# GCP BigQuery
BIGQUERY_DATASET=market_data
EXECUTION_BIGQUERY_DATASET=execution

# =============================================================================
# AWS CONFIGURATION (when CLOUD_PROVIDER=aws)
# =============================================================================
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=default  # Optional: Use named profile instead of env credentials

# AWS Storage Buckets (S3)
INSTRUMENTS_S3_BUCKET_CEFI=unified-trading-instruments-cefi-123456789012
INSTRUMENTS_S3_BUCKET_TRADFI=unified-trading-instruments-tradfi-123456789012
INSTRUMENTS_S3_BUCKET_DEFI=unified-trading-instruments-defi-123456789012
MARKET_DATA_S3_BUCKET_CEFI=unified-trading-market-data-cefi-123456789012
MARKET_DATA_S3_BUCKET_TRADFI=unified-trading-market-data-tradfi-123456789012
MARKET_DATA_S3_BUCKET_DEFI=unified-trading-market-data-defi-123456789012
FEATURES_S3_BUCKET=unified-trading-features-123456789012
EXECUTION_S3_BUCKET=unified-trading-execution-123456789012
ML_MODELS_S3_BUCKET=unified-trading-ml-models-123456789012

# AWS Athena (BigQuery equivalent)
ATHENA_DATABASE=market_data
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://unified-trading-athena-results-123456789012/

# =============================================================================
# API KEYS (via Secret Manager)
# =============================================================================
# These are fetched from Secret Manager automatically
# Set here only for local development without Secret Manager
# TARDIS_API_KEY=your-tardis-key
# DATABENTO_API_KEY=your-databento-key
# THE_GRAPH_API_KEY=your-graph-key
# ALCHEMY_API_KEY=your-alchemy-key

# Secret Manager configuration
USE_SECRET_MANAGER=true
TARDIS_SECRET_NAME=tardis-api-key
DATABENTO_SECRET_NAME=databento-api-key
# Round-robin: thegraph-api-key, thegraph-api-key-2 ... thegraph-api-key-9 (9 keys via SHARD_INDEX)
THEGRAPH_SECRET_NAME=thegraph-api-key
ALCHEMY_SECRET_NAME=alchemy-api-key

# Databento batch and rate limiting
DATABENTO_BATCH_REGISTRY_BUCKET=databento-batch-registry-asia-{project_id}  # GCS bucket for batch job registry (cross-key dedup, asia-northeast1)
# Target utilization (0.0-1.0): limits = floor(raw_limit * target). Default 0.8 = 80% of Databento limits.
# Cooldown matches limit window: per-second → 1s backoff, per-minute → 60s backoff.
DATABENTO_RATE_LIMIT_TARGET_UTILIZATION=0.8

# =============================================================================
# SERVICE-SPECIFIC CONFIGURATION
# =============================================================================
# Add your service-specific environment variables below
