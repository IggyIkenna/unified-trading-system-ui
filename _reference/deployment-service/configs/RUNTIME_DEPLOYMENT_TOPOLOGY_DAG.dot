digraph topology {
	graph [bgcolor="#fafbfc" compound=true fontname=Arial fontsize=11 label="Runtime Deployment Topology DAG v9\n7-layer pipeline: L1-L5 shared | L6-L7 client\nSSOT: runtime-topology.yaml | Decisions: RUNTIME_TOPOLOGY_DECISIONS.md" labelloc=t nodesep=0.4 pad=0.5 rankdir=TB ranksep=0.6]
	node [fontname=Arial fontsize=9]
	edge [fontname=Arial fontsize=8]
	subgraph cluster_l1 {
		bgcolor="#f0f7ff" color="#3b82f6" label="L1 -- Data Ingestion" style=rounded
		IS [label="instruments-service\n~15min poll, PubSub events\nB: cat x venue x date | L: venue" color="#3b82f6" fillcolor="#dbeafe" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		MTDH [label="market-tick-data-service\ncontinuous stream (WebSocket)\nB: cat x venue x inst_type x data_type x date" color="#3b82f6" fillcolor="#dbeafe" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_l2 {
		bgcolor="#f0f9ff" color="#0284c7" label="L2 -- Market Data Processing" style=rounded
		MDPS [label="market-data-processing-service\n~15s timer, candles\nB: cat x venue x inst_type x date x tf" color="#0284c7" fillcolor="#e0f2fe" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_l3 {
		bgcolor="#f0fdf4" color="#16a34a" label="L3 -- Feature Computation" style=rounded
		FCS [label="features-calendar-svc\nB: cat x date (batch only)" color="#16a34a" fillcolor="#dcfce7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		FDS [label="features-delta-one-svc\nB: cat x venue x feat_cat x date\nMDPS event" color="#16a34a" fillcolor="#dcfce7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		FVS [label="features-volatility-svc\nB: cat x venue x feat_cat x date\nMDPS event" color="#16a34a" fillcolor="#dcfce7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		FOS [label="features-onchain-svc\nB: proto x chain x date (batch)" color="#16a34a" fillcolor="#dcfce7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_l4 {
		bgcolor="#fffbeb" color="#d97706" label="L4 -- Cross-Instrument + Multi-Timeframe" style=rounded
		FCIS [label="features-cross-instrument-svc\nAggregates FDS + FVS + MDPS\nB: cat x feat_cat x date" color="#d97706" fillcolor="#fef3c7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		FMTS [label="features-multi-timeframe-svc\nFDS 5m/15m/1h/4h/1d\ntf_momentum | tf_structure | tf_vol | tf_session\n(PLANNED)" color="#ca8a04" fillcolor="#fefce8" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style="dashed,filled"]
	}
	subgraph cluster_l5 {
		bgcolor="#fffbeb" color="#d97706" label="L5 -- ML Pipeline" style=rounded
		MLTR [label="ml-training-service\nB: model x inst x tf x target x cfg\n~quarterly (batch only)" color="#d97706" fillcolor="#fef3c7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		MLIN [label="ml-inference-service\nB: model x venue x inst x date\nL: model x venue x inst" color="#d97706" fillcolor="#fef3c7" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_l6 {
		bgcolor="#fef2f2" color="#dc2626" label="L6 -- Strategy and Execution" style=rounded
		STR [label="strategy-service\nB: strategy_id x client x date\nL: strategy_id x client" color="#dc2626" fillcolor="#fee2e2" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		EXEC [label="execution-service\nB: client x subaccount x date\nL: client x subaccount" color="#dc2626" fillcolor="#fee2e2" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_l7 {
		bgcolor="#fdf2f8" color="#db2777" label="L7 -- Risk, PnL, Monitoring" style=rounded
		PBM [label="position-balance-monitor-service\nevent-driven (fills + exchange recon)" color="#db2777" fillcolor="#fce7f3" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		RAE [label="risk-and-exposure-svc\nevent-driven (positions + mktdata)" color="#db2777" fillcolor="#fce7f3" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		PNL [label="pnl-attribution-svc\nevent-driven (exec + risk)" color="#db2777" fillcolor="#fce7f3" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		ALT [label="alerting-service\nsingleton, circuit breakers" color="#db2777" fillcolor="#fce7f3" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_api {
		bgcolor="#faf5ff" color="#7c3aed" label="API Services (FastAPI + SSE)" style=rounded
		MDA [label="market-data-api\nSSE orderbook + candles\nSource: MTDH(PS) + MDPS(GCS)" color="#7c3aed" fillcolor="#f3e8ff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		ERA [label="execution-results-api\nSSE order lifecycle + fills\nSource: exec-svc (GCS+PS)" color="#7c3aed" fillcolor="#f3e8ff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		CRS [label="client-reporting-api\nbatch reports + live SSE PnL\nSource: PnL+risk+PBM (GCS)" color="#7c3aed" fillcolor="#f3e8ff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		DEPAPI [label="deployment-api\norchestration + kill-switch\nSource: deployment-engine" color="#7c3aed" fillcolor="#f3e8ff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		STRAPI [label="strategy-api\nbacktest results | signal configs\nSource: strategy-svc (GCS)\n(PLANNED)" color="#ca8a04" fillcolor="#fefce8" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style="dashed,filled"]
	}
	subgraph cluster_ui {
		bgcolor="#ecfeff" color="#06b6d4" label="UIs (React/TypeScript)" style=rounded
		subgraph cluster_ui_trading {
			color="#94a3b8" label="Trading + Monitoring" style="rounded,dashed"
			TAUI [label="trading-analytics-ui\nSSE fills, PnL dashboard\n-> ERA :8002" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			LHMU [label="live-health-monitor-ui\nSSE health, manual trading\n-> deployment-api :8001" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		}
		subgraph cluster_ui_batch {
			color="#94a3b8" label="Batch Research (3-tier)" style="rounded,dashed"
			MLUI [label="ml-training-ui\ntrain models, deploy batch->live\nfeature + candle plots\n-> deploy-api + market-data-api\n[repo: ml-deployment-ui]" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			STUI [label="strategy-ui\nstrategy backtest, param tuning\n-> strategy-api :8004" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			EXANI [label="execution-analytics-ui\nexecution backtest, TCA, alpha\n-> ERA + market-data-api\n[repo: backtest-ui]" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		}
		subgraph cluster_ui_ops {
			color="#94a3b8" label="Ops + Deployment" style="rounded,dashed"
			DEPUI [label="deployment-ui\nbatch vs live deployment\n-> deploy-api :8001" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			BAUI [label="batch-audit-ui\n-> deploy-api :8001" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			LGUI [label="logs-dashboard-ui\n-> deploy-api :8001" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			OBUI [label="onboarding-ui\nclient wizard\n-> deploy-api :8001" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		}
		subgraph cluster_ui_client {
			color="#94a3b8" label="Client + Reporting" style="rounded,dashed"
			CRUI [label="client-reporting-ui\n-> client-reporting-api :8003" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
			SETU [label="settlement-ui\n-> ERA :8002\n(not yet built)" color="#06b6d4" fillcolor="#ecfeff" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		}
	}
	subgraph cluster_infra {
		bgcolor="#f8fafc" color="#64748b" label=Infrastructure style=rounded
		DEPENG [label="deployment-engine\norchestrator + CLI + Terraform" color="#64748b" fillcolor="#f1f5f9" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
		SIT [label="system-integration-tests\nL3a smoke + L3b full E2E" color="#64748b" fillcolor="#f1f5f9" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=box style=filled]
	}
	subgraph cluster_store {
		bgcolor="#f0fdf4" color="#16a34a" label="Persistence + Transport" style=rounded
		GCS [label="GCS\nParquet batch bus" color="#16a34a" fillcolor="#f0fdf4" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=cylinder style=filled]
		PS [label="PubSub\nlive event bus" color="#16a34a" fillcolor="#f0fdf4" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=cylinder style=filled]
		REDIS [label="Redis\nhot order state" color="#16a34a" fillcolor="#f0fdf4" fontname=Arial fontsize=10 margin="0.15,0.08" penwidth=2 shape=cylinder style=filled]
	}
	IS -> MTDH [label=instruments color="#2563eb" penwidth=1.5]
	IS -> MTDH [label="events(PS)" color="#7c3aed" penwidth=1.5]
	MTDH -> MDPS [label="batch(GCS)" color="#2563eb" penwidth=1.5]
	MTDH -> MDPS [label="live(PS)" color="#7c3aed" penwidth=1.5]
	MTDH -> MDPS [label=co_located color="#ea580c" penwidth=1.5 style=dashed]
	MDPS -> FDS [label=candles color="#2563eb" penwidth=1.5]
	MDPS -> FDS [color="#7c3aed" penwidth=1.5]
	MDPS -> FVS [label=candles color="#2563eb" penwidth=1.5]
	MDPS -> FVS [color="#7c3aed" penwidth=1.5]
	FDS -> FCIS [label="cross-feat" color="#2563eb" penwidth=1.5]
	FVS -> FCIS [color="#2563eb" penwidth=1.5]
	MDPS -> FCIS [color="#2563eb" penwidth=1.5]
	FDS -> FMTS [label="multi-tf" color="#ca8a04" penwidth=1.2 style=dashed]
	FCIS -> MLTR [label=batch color="#2563eb" penwidth=1.5]
	FCIS -> MLIN [color="#2563eb" penwidth=1.5]
	FMTS -> MLTR [color="#ca8a04" penwidth=1.2 style=dashed]
	FMTS -> MLIN [color="#ca8a04" penwidth=1.2 style=dashed]
	FDS -> MLTR [label="features(batch)" color="#2563eb" penwidth=1.5]
	FDS -> MLIN [label="features(PS)" color="#7c3aed" penwidth=1.5]
	FVS -> MLIN [color="#7c3aed" penwidth=1.5]
	MLTR -> MLIN [label="models(~quarterly)" color="#2563eb" penwidth=1.5]
	MLIN -> STR [label=predictions color="#2563eb" penwidth=1.5]
	MLIN -> STR [color="#7c3aed" penwidth=1.5]
	MDPS -> STR [label="market data" color="#2563eb" penwidth=1.5]
	STR -> EXEC [label=orders color="#2563eb" penwidth=1.5]
	STR -> EXEC [color="#7c3aed" penwidth=1.5]
	EXEC -> STR [label=handshake color="#7c3aed" penwidth=1.5]
	MTDH -> EXEC [label="market feed(co_located)" color="#ea580c" penwidth=1.5 style=dashed]
	EXEC -> PBM [label="order lifecycle" color="#2563eb" penwidth=1.5]
	EXEC -> PBM [color="#7c3aed" penwidth=1.5]
	EXEC -> PNL [color="#2563eb" penwidth=1.5]
	EXEC -> PNL [color="#7c3aed" penwidth=1.5]
	PBM -> STR [label="position(PBM=authority)" color="#7c3aed" penwidth=1.5]
	PBM -> RAE [color="#2563eb" penwidth=1.5]
	PBM -> RAE [color="#7c3aed" penwidth=1.5]
	RAE -> PNL [color="#2563eb" penwidth=1.5]
	RAE -> PNL [color="#7c3aed" penwidth=1.5]
	ALT -> EXEC [label="CIRCUIT BREAKER" color="#dc2626" penwidth=1.8 style=dashed]
	ALT -> STR [color="#dc2626" penwidth=1.8 style=dashed]
	RAE -> ALT [label="alerts(PS)" color="#7c3aed" penwidth=1.5]
	PBM -> ALT [color="#7c3aed" penwidth=1.5]
	EXEC -> ALT [color="#7c3aed" penwidth=1.5]
	MTDH -> MDA [label="ticks(PS)" color="#7c3aed" penwidth=1.5]
	MDPS -> MDA [label="candles(GCS)" color="#2563eb" penwidth=1.5]
	EXEC -> ERA [label="fills(GCS+PS)" color="#2563eb" penwidth=1.5]
	PNL -> CRS [label="reports(GCS)" color="#2563eb" penwidth=1.5]
	RAE -> CRS [color="#2563eb" penwidth=1.5]
	PBM -> CRS [color="#2563eb" penwidth=1.5]
	DEPENG -> DEPAPI [color="#06b6d4" penwidth=1.2]
	STR -> STRAPI [label="signals(GCS)" color="#ca8a04" penwidth=1.2 style=dashed]
	ERA -> TAUI [color="#06b6d4" penwidth=1.2]
	ERA -> EXANI [color="#06b6d4" penwidth=1.2]
	ERA -> SETU [color="#06b6d4" penwidth=1.2]
	MDA -> EXANI [label="candles+ticks" color="#06b6d4" penwidth=1.2]
	MDA -> MLUI [label="feature plots" color="#06b6d4" penwidth=1.2]
	STRAPI -> STUI [color="#06b6d4" penwidth=1.2 style=dashed]
	CRS -> CRUI [color="#06b6d4" penwidth=1.2]
	DEPAPI -> DEPUI [color="#06b6d4" penwidth=1.2]
	DEPAPI -> LHMU [color="#06b6d4" penwidth=1.2]
	DEPAPI -> BAUI [color="#06b6d4" penwidth=1.2]
	DEPAPI -> LGUI [color="#06b6d4" penwidth=1.2]
	DEPAPI -> OBUI [color="#06b6d4" penwidth=1.2]
	DEPAPI -> MLUI [label="deploy hook" color="#06b6d4" penwidth=1.2]
	DEPAPI -> STUI [label="deploy hook" color="#06b6d4" penwidth=1.2]
	DEPAPI -> SIT [label="post-deploy" color="#64748b" style=dashed]
	DEPENG -> GCS [label=provisions color="#64748b" style=dashed]
	IS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	MTDH -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	MDPS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	FCS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	FDS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	FVS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	FOS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	FCIS -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	MLTR -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	MLIN -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	STR -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	EXEC -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	PBM -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	RAE -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	PNL -> GCS [arrowsize=0.6 color="#16a34a" penwidth=0.8 style=dotted]
	MTDH -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	MDPS -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	FDS -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	FVS -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	MLIN -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	STR -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	EXEC -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	PBM -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	RAE -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	PNL -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	ALT -> PS [arrowsize=0.5 color="#7c3aed" penwidth=0.6 style=dotted]
	EXEC -> REDIS [label="hot state" color="#16a34a" penwidth=0.8 style=dotted]
}
