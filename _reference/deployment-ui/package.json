{
  "name": "deployment-ui",
  "version": "0.1.0",
  "description": "Deployment management UI — orchestrator status, shard progress, Cloud Build logs, service health",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoketest": "playwright test",
    "smoketest-no-compile": "playwright test --no-deps",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@unified-admin/core": "file:../unified-admin-ui/packages/core",
    "@unified-trading/ui-auth": "file:../unified-trading-ui-auth",
    "@unified-trading/ui-kit": "file:../unified-trading-ui-kit",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.3.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
