# deployment-ui Configuration
VITE_DEPLOYMENT_API_URL=http://localhost:8004
VITE_SKIP_AUTH=true

# Auth provider: google (default) | cognito
VITE_AUTH_PROVIDER=google

# Google OAuth — used when VITE_AUTH_PROVIDER=google
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# AWS Cognito OAuth PKCE — used when VITE_AUTH_PROVIDER=cognito
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id
VITE_COGNITO_DOMAIN=https://your-user-pool-domain.auth.ap-northeast-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
