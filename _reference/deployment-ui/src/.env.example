# deployment-ui environment variables
# Copy to .env.local and fill in values

# deployment-api base URL
# (GET /api/v1/services, POST /api/v1/deployments, GET /api/v1/deployments, POST /api/v1/deployments/:id/rollback)
VITE_DEPLOYMENT_API_URL=http://localhost:8004

# Google OAuth client ID (leave blank to skip auth in dev)
VITE_GOOGLE_CLIENT_ID=

# Set to 'true' to bypass auth in development
VITE_SKIP_AUTH=true
