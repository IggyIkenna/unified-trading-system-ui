# Integration mode — real API data + demo auth (no OAuth needed, real backend required)
# Usage: cp .env.integration .env.local && npm run dev
# Requires: backend APIs running (client-reporting-api on 8014, trading-api on 8004, etc.)
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_AUTH_PROVIDER=demo
NEXT_PUBLIC_SKIP_AUTH=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8004
NEXT_PUBLIC_USER_MGMT_API_URL=http://localhost:8017
